@article{SurveyEmrouznejad2014,
author = {Emrouznejad, Ali and Marra, Marianna},
title = {Ordered Weighted Averaging Operators 1988–2014: A Citation-Based Literature Survey},
journal = {International Journal of Intelligent Systems},
volume = {29},
number = {11},
pages = {994-1014},
doi = {https://doi.org/10.1002/int.21673},
url = {https://onlinelibrary.wiley.com/doi/abs/10.1002/int.21673},
eprint = {https://onlinelibrary.wiley.com/doi/pdf/10.1002/int.21673},
abstract = {This study surveys the ordered weighted averaging (OWA) operator literature using a citation network analysis. The main goals are the historical reconstruction of scientific development of the OWA field, the identification of the dominant direction of knowledge accumulation that emerged since the publication of the first OWA paper, and to discover the most active lines of research. The results suggest, as expected, that Yager's paper (IEEE Trans. Systems Man Cybernet, 18(1), 183–190, 1988) is the most influential paper and the starting point of all other research using OWA. Starting from his contribution, other lines of research developed and we describe them.},
year = {2014}
}


