@article{mareschal1988weight,
title = {Weight stability intervals in multicriteria decision aid},
journal = {European Journal of Operational Research},
volume = {33},
number = {1},
pages = {54-64},
year = {1988},
issn = {0377-2217},
doi = {https://doi.org/10.1016/0377-2217(88)90254-8},
url = {https://www.sciencedirect.com/science/article/pii/0377221788902548},
author = {Bertrand Mareschal},
keywords = {Decision, multiple criteria programming, weights},
abstract = {In this paper we study the stability of the results given by a wide class of MCDA methods to changes of the weights of the criteria. Three aspects of stability are discussed. In each case we propose to construct stability intervals for the weights of either single criteria or groups of criteria. A necessary and sufficient condition for stability is also considered. The use of these instruments is demonstrated with a numerical example.}
}


@article{wolters1995novel,
title = {Novel types of sensitivity analysis for additive MCDM methods},
journal = {European Journal of Operational Research},
volume = {81},
number = {2},
pages = {281-290},
year = {1995},
issn = {0377-2217},
doi = {https://doi.org/10.1016/0377-2217(93)E0343-V},
url = {https://www.sciencedirect.com/science/article/pii/0377221793E0343V},
author = {W.T.M. Wolters and B. Mareschal},
keywords = {Multiple criteria, Sensitivity analysis},
abstract = {Three novel types of sensitivity analysis are presented. They determine the following: 1) the sensitivity of a ranking to specific changes in the evaluations of all alternatives on certain criteria; 2) the influence of specific changes in certain criterion-scores of an alternative; 3) the minimum modification of the weights required to make an alternative ranked first. The use of these instruments is demonstrated by the results of a simulation experiment. Results show that the first and second type of sensitivity analysis enable to apply multiple criteria decision making (MCDM) methods in dynamic circumstances. The third type of sensitivity analysis is demonstrated to be a tool to analyze the total weight space.}
}