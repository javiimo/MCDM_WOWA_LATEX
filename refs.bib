@article{Consueloroadef,
title = {A matheuristic algorithm for the maintenance planning problem at an electricity transmission system operator},
journal = {Expert Systems with Applications},
volume = {230},
pages = {120583},
year = {2023},
issn = {0957-4174},
doi = {https://doi.org/10.1016/j.eswa.2023.120583},
url = {https://www.sciencedirect.com/science/article/pii/S0957417423010850},
author = {Francisco Parreño and Consuelo Parreño-Torres and Ramon Alvarez-Valdes},
keywords = {Maintenance planning, Integer models, Matheuristics, Variable neighbourhood descent},
abstract = {When planning maintenance tasks involving the switching off of parts of the network, electricity transmission operators must evaluate and take into account the associated risks. The French operator, RTE, has developed a three-step approach in which they first calculate the risks in every possible scenario, then plan the maintenance tasks by optimizing some risk measures, and finally validate the plan. In this paper, we have addressed the second step, developing mathematical models that approximate the original problem as well as a matheuristic algorithm. It is composed of three phases, combining integer linear models in the first phase with metaheuristics such as Variable Neighbourhood Descent and Path Relinking in the second and third phases. The computational results obtained on the benchmarks provided by the company show that our algorithm improves on the best reported solutions for most of the test instances.},
note = {Code available at \url{https://github.com/FranciscoParrenoTorres/Roadef2020}, accessed February 2025}
}


